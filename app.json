{
  "expo": {
    "name": "react-camara",
    "slug": "react-camara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reactcamara.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.reactcamara.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Esta app necesita acceso a la cámara para tomar fotos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Esta app necesita acceso a la galería para guardar fotos.",
          "savePhotosPermission": "Esta app necesita permiso para guardar fotos en la galería."
        }
      ]
    ]
  }
}
